{
    "patterns": [
      {
        "pattern": "^(?:#\\S+\\s*)+\\n\\s*\\n([^\\n]+)",
        "description": "Title after a line of hashtags: #tag1 #tag2\\n\\ntitle content"
      },
      {
        "pattern": "^#[^\\s]+\\s+\\*\\*([^\\*]+?)\\*\\*",
        "description": "Bold title with hashtag: #tag **title**"
      },
      {
        "pattern": "^#[^\\s]+\\s+(.+?)(?=\\n|$)",
        "description": "Title with hashtag: #tag title content"
      },
      {
        "pattern": "^\\[\\*\\*([^\\*]+?)\\*\\*\\]\\([^\\)]+?\\)",
        "description": "Bold linked title: [**title**](url)"
      },
      {
        "pattern": "^\\[([^\\]]+?)\\]\\([^\\)]+?\\)",
        "description": "Linked title: [title](url)"
      },
      {
        "pattern": "^\\*\\*([^\\*]+?)\\*\\*",
        "description": "Bold title: **title**"
      },
      {
        "pattern": "^【([^】]+?)】",
        "description": "CJK bracket title: 【title】"
      },
      {
        "pattern": "^\\[([^\\]]+?)\\]",
        "description": "Bracket title: [title]"
      },
      {
        "pattern": "^(.+?)\\n",
        "description": "First line as title"
      }
    ]
  }
