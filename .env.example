######### Required #########
# Telegram API credentials (get from https://my.telegram.org/apps)
API_ID=
API_HASH=

# Phone number for user account login (format: +14155552671)
PHONE_NUMBER=

# Bot Token
BOT_TOKEN=

# Your Telegram user ID (get from @userinfobot)
USER_ID=



################ Optional ##################

# Admin list (enter user_ids here; leave blank to default to USER_ID above; separate multiple users with commas)
ADMINS=

# Bot message auto-delete timeout (seconds); 0 = delete immediately, -1 = never delete
BOT_MESSAGE_DELETE_TIMEOUT=300

# Auto-delete user command messages after processing (true/false)
USER_MESSAGE_DELETE_ENABLE=false

# Default maximum media file size limit (MB)
DEFAULT_MAX_MEDIA_SIZE=15

# Default timezone
DEFAULT_TIMEZONE=America/New_York

# Time to auto-update chat names in the database (24-hour format)
CHAT_UPDATE_TIME=03:00

# Database configuration
DATABASE_URL=sqlite:///./db/forward.db

######### UI Layout #########
AI_MODELS_PER_PAGE=10
KEYWORDS_PER_PAGE=10
PUSH_CHANNEL_PER_PAGE=10

# Summary time list (rows)
SUMMARY_TIME_ROWS=10
# Summary time list (columns)
SUMMARY_TIME_COLS=6

# Delay time list (rows)
DELAY_TIME_ROWS=10
# Delay time list (columns)
DELAY_TIME_COLS=6

# Media size list (rows)
MEDIA_SIZE_ROWS=10
# Media size list (columns)
MEDIA_SIZE_COLS=6

# Media extension list (rows)
MEDIA_EXTENSIONS_ROWS=10
# Media extension list (columns)
MEDIA_EXTENSIONS_COLS=6

# Number of rules per page
RULES_PER_PAGE=20

######### AI Settings #########

# Default AI model
DEFAULT_AI_MODEL=gemini-2.0-flash

# OpenAI API Key
OPENAI_API_KEY=your_openai_api_key
# Leave blank to use the official endpoint: https://api.openai.com/v1
OPENAI_API_BASE=

# Claude API Key
CLAUDE_API_KEY=your_claude_api_key
# Leave blank to use the official endpoint
CLAUDE_API_BASE=

# Gemini API Key
# Uses official endpoint by default
GEMINI_API_KEY=your_gemini_api_key
# OpenAI-compatible third-party API base, e.g. official: https://generativelanguage.googleapis.com/v1beta
GEMINI_API_BASE=

# DeepSeek API Key
DEEPSEEK_API_KEY=your_deepseek_api_key
# Leave blank to use the official endpoint: https://api.deepseek.com/v1
DEEPSEEK_API_BASE=

# Qwen API Key
QWEN_API_KEY=your_qwen_api_key
# Leave blank to use the official endpoint: https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_API_BASE=

# Grok API Key
GROK_API_KEY=your_grok_api_key
# Leave blank to use the official endpoint: https://api.x.ai/v1
GROK_API_BASE=

# Default AI processing prompt
DEFAULT_AI_PROMPT=Please rewrite the following content in English, preserving the original meaning and formatting:

# Default AI summary prompt
DEFAULT_SUMMARY_PROMPT=Please summarize the messages from this channel/group over the past 24 hours.
# Default summary time (24-hour format)
DEFAULT_SUMMARY_TIME=07:00


# Number of messages to fetch per AI summary batch
SUMMARY_BATCH_SIZE=20
# Delay between AI summary batch fetches (seconds)
SUMMARY_BATCH_DELAY=2


######### RSS Configuration #########
# Enable RSS feature (true/false)
RSS_ENABLED=false

# RSS base access URL
RSS_BASE_URL=

# RSS media file base URL
RSS_MEDIA_BASE_URL=


######### Extensions #########

# Enable sync with Universal Forum Block (UFB) plugin server (true/false)
UFB_ENABLED=false
# UFB server address
UFB_SERVER_URL=
# UFB user API key
UFB_TOKEN=




